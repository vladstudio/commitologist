{
  "name": "commitologist-monorepo",
  "description": "Generate commit messages using Tetra",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "packages/vscode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vladstudio/commitologist.git"
  },
  "scripts": {
    "build": "cd packages/vscode && bun run build",
    "watch": "cd packages/vscode && bun run watch",
    "clean": "cd packages/vscode && bun run clean",
    "lint": "biome check packages/vscode/src || true",
    "lint:fix": "biome check --fix packages/vscode/src || true",
    "format": "biome format --write packages/vscode/src || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@types/node": "^24.1.0",
    "typescript": "^5.8.3"
  }
}

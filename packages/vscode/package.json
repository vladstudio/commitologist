{
  "name": "commitologist",
  "displayName": "Commitologist",
  "description": "Generate commit messages using Tetra",
  "version": "0.2.0",
  "publisher": "vladstudio",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "commit-message",
    "productivity",
    "source-control"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vladstudio/commitologist.git",
    "directory": "packages/vscode"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:commitologist.generateMessage"
  ],
  "contributes": {
    "commands": [
      {
        "command": "commitologist.generateMessage",
        "title": "Commitologist: Generate Commit Message",
        "icon": {
          "light": "icon.svg",
          "dark": "icon-dark.svg"
        }
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commitologist.generateMessage",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "commitologist.generateMessage",
          "when": "scmProvider == git"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node16",
    "watch": "bun run build --watch",
    "clean": "rm -rf dist",
    "test": "bun test",
    "vscode:prepublish": "bun run build",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.102.0",
    "esbuild": "^0.25.8"
  },
  "extensionDependencies": [
    "vscode.git"
  ]
}
